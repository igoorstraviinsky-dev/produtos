generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           String   @id @default(uuid()) @db.Uuid
  legalName    String   @map("legal_name")
  externalCode String   @unique @map("external_code")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  apiKeys      ApiKey[]
  inventories  CompanyInventory[]

  @@map("companies")
}

model ApiKey {
  id                 String    @id @default(uuid()) @db.Uuid
  companyId          String    @map("company_id") @db.Uuid
  keyPrefix          String    @map("key_prefix") @db.VarChar(12)
  keyHash            String    @unique @map("key_hash") @db.VarChar(128)
  rateLimitPerMinute Int       @map("rate_limit_per_minute")
  isRevoked          Boolean   @default(false) @map("is_revoked")
  revokedAt          DateTime? @map("revoked_at")
  lastUsedAt         DateTime? @map("last_used_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId], map: "idx_api_keys_company_id")
  @@map("api_keys")
}

model MasterProduct {
  id                 String             @id
  sku                String
  name               String
  masterStock        Int                @map("master_stock")
  updatedAt          DateTime           @map("updated_at")
  companyInventories CompanyInventory[]
  variants           ProductVariant[]

  @@map("master_products")
}

model ProductVariant {
  id            String        @id
  productId     String        @map("product_id")
  sku           String
  individualWeight Float?     @map("individual_weight")
  individualStock  Int        @default(0) @map("individual_stock")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  product       MasterProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "idx_product_variants_product_id")
  @@map("product_variants")
}

model CostSettings {
  id                     String   @id @default("default")
  silverPricePerGram     Float    @default(1) @map("silver_price_per_gram")
  zonaFrancaRatePercent  Float    @default(6) @map("zona_franca_rate_percent")
  transportFee           Float    @default(0.1) @map("transport_fee")
  dollarRate             Float    @default(5) @map("dollar_rate")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("cost_settings")
}

model CostSettingsHistory {
  id                            String   @id @default(uuid()) @db.Uuid
  previousSilverPricePerGram    Float    @map("previous_silver_price_per_gram")
  nextSilverPricePerGram        Float    @map("next_silver_price_per_gram")
  previousZonaFrancaRatePercent Float    @map("previous_zona_franca_rate_percent")
  nextZonaFrancaRatePercent     Float    @map("next_zona_franca_rate_percent")
  previousTransportFee          Float    @map("previous_transport_fee")
  nextTransportFee              Float    @map("next_transport_fee")
  previousDollarRate            Float    @map("previous_dollar_rate")
  nextDollarRate                Float    @map("next_dollar_rate")
  changedFields                 String   @map("changed_fields")
  createdAt                     DateTime @default(now()) @map("created_at")

  @@map("cost_settings_history")
}

model CompanyInventory {
  id                  String        @id @default(uuid()) @db.Uuid
  companyId           String        @map("company_id") @db.Uuid
  productId           String        @map("product_id")
  customStockQuantity Int           @map("custom_stock_quantity")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  company             Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product             MasterProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId], map: "uq_company_inventory_company_product")
  @@index([companyId], map: "idx_company_inventory_company_id")
  @@index([productId], map: "idx_company_inventory_product_id")
  @@map("company_inventory")
}
