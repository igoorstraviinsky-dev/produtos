{
  "name": "b2b-stock-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "API Gateway de Estoque B2B com Zero Trust, PostgreSQL, Redis e Supabase",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "ver-estoque": "node scripts/ver-estoque.mjs",
    "benchmark:api": "node scripts/benchmark-api.mjs",
    "test": "npm run build && node tests/run.cjs",
    "test:watch": "npm run test",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@prisma/client": "^6.8.2",
    "@supabase/supabase-js": "^2.49.11",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "autocannon": "^8.0.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3",
    "yaml": "^2.8.0"
  }
}
